---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import CardAbout from './CardAbout';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="max-w-4xl mx-auto mt-20">
  <h2 id="about" class="text-4xl font-bold text-center text-gray-800">{t('about')}</h2>

  <div class="flex justify-center md:mt-20">
    <!-- Desktop profile card -->
    <div
      class="rounded overflow-hidden shadow-lg hidden md:block"
      style="height: 420px; width: 285px;"
      data-sal="slide-right"
      data-sal-delay="300"
      data-sal-easing="easeInSine"
    >
      <CardAbout client:visible idImg="toggleImageMD" idCheckbox="toggleCheckBoxMD" height="380px" width="285px" />
    </div>

    <!-- Text content -->
    <div
      class="ml-0 mt-12 md:ml-6 lg:ml-20"
      data-sal="slide-left"
      data-sal-delay="300"
      data-sal-easing="easeInSine"
    >
      <h3 class="text-2xl font-bold text-center text-gray-700">{t('introduce_h1')}</h3>
      <h3 class="text-2xl font-bold text-center text-gray-700">{t('introduce_h2')}</h3>

      <!-- Desktop text -->
      <div class="text-base font-light text-center text-gray-700 mt-5 hidden md:block">
        <p>{t('introduce_p1')}</p>
        <p>{t('introduce_p2')}</p>
        <p>{t('introduce_p3')}</p>
        <p>{t('introduce_p4')}</p>
        <p>{t('introduce_p5')}</p>
        <p>{t('introduce_p6')}</p>
        <p>{t('introduce_p7')}</p>
        <p>{t('introduce_p8')}</p>
      </div>

      <!-- Mobile text -->
      <div class="text-base font-light text-center text-gray-700 ml-3 mt-5 block md:hidden">
        <p>{t('introduce_pm1')}</p>
        <p>{t('introduce_pm2')}</p>
        <p>{t('introduce_pm3')}</p>
        <p>{t('introduce_pm4')}</p>
        <p>{t('introduce_pm5')}</p>
        <p>{t('introduce_pm6')}</p>
        <p>{t('introduce_pm7')}</p>
        <p>{t('introduce_pm8')}</p>
        <p>{t('introduce_pm9')}</p>
        <p>{t('introduce_pm10')}</p>
        <p>{t('introduce_pm11')}</p>
        <p>{t('introduce_pm12')}</p>
      </div>
    </div>
  </div>

  <!-- Mobile profile card -->
  <div class="flex justify-center mt-10 block md:hidden">
    <div
      class="rounded overflow-hidden shadow-lg"
      style="height: 353px; width: 235px;"
      data-sal="slide-right"
      data-sal-delay="300"
      data-sal-easing="easeInSine"
    >
      <CardAbout client:visible idImg="toggleImageSM" idCheckbox="toggleCheckBoxSM" height="313px" width="235px" />
    </div>
  </div>
</div>
